# Пример .env — скопировать и заполнить своими значениями: cp .env.example .env
# (.env в .gitignore; секреты в репозиторий не коммитим)

# ----- PostgreSQL -----
DATABASE=Program
PG_USER=postgres
PG_PASSWORD=changeme
PG_HOST=localhost
PG_PORT=6442                     # порт PgBouncer/PG (по умолчанию в коде 5432)

# ----- Telegram: каналы логгера + бот ошибок -----
ERROR_CHANNEL=-1000000000000
MESSAGE_CHANNEL=-1000000000000
COOKIES_CHANNEL=-1000000000000
# SESSION_CHANNEL — выделенный канал для критичных алертов отвала session юзербота
# (§3.3; необязателен — без него алерты идут в ERROR_CHANNEL, но НЕ в шумный cookies-канал).
# SESSION_CHANNEL=-1000000000000
TOKEN='0000000000:AA-replace-with-bot-token'   # @optionerror_bot

# ----- Перекрытия (догоны) -----
OVERLAP=3                        # количество догонов
OVERLAP_RANDOM=2                 # количество рандомных догонов

# ----- Тайминг/детект (необязательные, есть дефолты) -----
# MAIN_CYCLE_PAUSE_MIN=100        # пауза между циклами main, нижняя граница, сек (§7)
# MAIN_CYCLE_PAUSE_MAX=120        # верхняя граница; пауза = randint(MIN,MAX), для OTC +30

# ----- База данных опционов + ключ программы -----
DATABASE_FIN=binodex             # option_data.*, cookies.binodex_cookies, settings.option_setting
PROG_KEY=bino_option             # фильтр своих строк в общей settings.option_setting (колонка program)

# ============================================================
# Необязательное (раскомментировать при необходимости)
# ============================================================
# TIMEFRAME/BINARY обычно задаёт диспетчер per-instance (process env), не этот файл.
# Для локального запуска одного экземпляра можно указать здесь:
# TIMEFRAME=1m                   # 1m | 3m | 5m | 10m | 15m
# BINARY=0                       # 1 — FIN (TradingView), 0 — OTC (binodex)

# Тест-режим (§2): креды юзербота и канал берутся из env ниже, а не из БД;
# session — файловая (TEST_SESSION_FILE под files/), не in_memory:
# TEST=1
# TEST_CHANNEL=-1000000000000
# TEST_API_ID=
# TEST_API_HASH=
# TEST_SESSION_FILE=files/My_session

# Подмена OTC storage_state: user_id строки в binodex.cookies.binodex_cookies:
# COOK_OTC=
# Переадресация основных сигналов в другой канал:
# SIGNAL_CHANNEL=