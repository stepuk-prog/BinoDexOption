[Unit]
Description=OPTION 3 MIN BINARY
After=network.target

[Service]
User=vova
Group=vova

WorkingDirectory=/home/vova/Options/Binary/3min/
Environment="PYTHONPATH=/home/vova/Options/Binary/3min/"
ExecStart=/home/vova/Options/Binary/3min/venv/bin/python3.11 /home/vova/Options/Binary/3min/bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target