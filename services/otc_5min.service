[Unit]
Description=OPTION 5 MIN OTC
After=network.target

[Service]
User=vova
Group=vova

WorkingDirectory=/home/vova/Options/OTC/5min/
Environment="PYTHONPATH=/home/vova/Options/OTC/5min/"
ExecStart=/home/vova/Options/OTC/5min/venv/bin/python3.11 /home/vova/Options/OTC/5min/bot.py
Restart=on-failure
RestartSec=10
[Install]
WantedBy=multi-user.target