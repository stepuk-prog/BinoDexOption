[Unit]
Description=OPTION 15 MIN BINARY
After=network.target

[Service]
User=vova
Group=vova

WorkingDirectory=/home/vova/Options/Binary/15min/
Environment="PYTHONPATH=/home/vova/Options/Binary/15min/"
ExecStart=/home/vova/Options/Binary/15min/venv/bin/python3.11 /home/vova/Options/Binary/15min/bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target