[Unit]
Description=Option Bot 10m Binary
After=network.target

[Service]
Type=simple
User=vova
WorkingDirectory=/home/vova/Options
Environment="TIMEFRAME=10m" "BINARY=true" "TEST=false"
ExecStart=/home/vova/Options/.venv/bin/python3.11 bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
